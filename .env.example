# Get a key at https://console.deepgram.com/ (needs at least "Member" permissions
# so it can mint short-lived tokens via /v1/auth/grant).
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Used by the per-turn scoring judge (a small Anthropic/Claude call the brain makes
# itself, separate from the in-pipeline agent LLM). Without it the game still runs —
# every turn just scores the minimum (100) instead of being graded 100/500/1000.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: which heists are enabled (comma-separated ids). Omit for all four.
# VOICE_HEIST_AVAILABLE=order,refund,receptionist,list

# Optional: event timezone — drives the daily "one play per scenario per day" reset.
EVENT_TZ=America/New_York

# Optional: port for the Python brain (default 8000).
PORT=8000

# Optional: SQLite path (dev defaults to ./voice-heist.db).
# VH_DB_PATH=./voice-heist.db

# Optional player identity (name+email sign-up / code sign-in). Set a long, random
# secret in production so sign-in cookies survive restarts and can't be forged; if
# unset, the demo falls back to an insecure, process-ephemeral dev value.
# VH_SIGNING_SECRET=change-me-to-a-long-random-string

# Optional: set to 1 to mark the sign-in cookie Secure (HTTPS only). Enable in prod.
# COOKIE_SECURE=0
